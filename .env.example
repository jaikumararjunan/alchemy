# =============================================================================
# Alchemy — Environment Variables
# Copy to .env and fill in your actual values.
# =============================================================================

# ── Delta Exchange API ────────────────────────────────────────────────────────
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here
DELTA_BASE_URL=https://api.india.delta.exchange

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── News API (optional — geopolitical sentiment) ─────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ── Trading Config ────────────────────────────────────────────────────────────
TRADING_SYMBOL=BTCUSD
POSITION_SIZE_USD=100
MAX_OPEN_POSITIONS=3
RISK_PER_TRADE_PCT=1.0
BULLISH_THRESHOLD=0.6
BEARISH_THRESHOLD=-0.6
WATCH_LIST=BTCUSD,ETHUSD,SOLUSD,BNBUSD,XRPUSD
TOP_CONTRACTS_TO_TRADE=3
SCAN_ALL_CONTRACTS=false

# ── Safety: start in paper-trading mode ──────────────────────────────────────
DRY_RUN=true

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_use_strong_password

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
